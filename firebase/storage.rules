rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload post images
    match /posts/images/{imageId} {
      allow write: if request.auth != null;
      allow read: if true;
    }

    // Allow authenticated users to upload promocode images
    match /promocodes/images/{imageId} {
      allow write: if request.auth != null;
      allow read: if true;
    }
  }
}
